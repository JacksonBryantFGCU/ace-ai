# Copy to .env.local and fill in. .env.local is gitignored; this file is committed.

# --- Public (safe to expose; inlined into the client bundle) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Vapi public key — the voice interview client (Phase 4). Public by design.
NEXT_PUBLIC_VAPI_PUBLIC_KEY=

# --- Server-only secrets (NEVER prefix with NEXT_PUBLIC) ---
# Service-role key — privileged DB writes via the admin client (bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=
# OpenAI — transcript evaluation (Phase 3).
OPENAI_API_KEY=
# Optional; defaults to gpt-4o-mini.
OPENAI_MODEL=

# --- Stripe — time passes (P1) ---
# Secret key + webhook signing secret.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# One-time Price IDs for the Day Pass ($5 / 24h) and Week Pass ($15 / 7d).
STRIPE_PRICE_DAY_PASS=
STRIPE_PRICE_WEEK_PASS=
